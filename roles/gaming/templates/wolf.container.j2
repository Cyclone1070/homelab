[Unit]
Description=Wolf / Games On Whales
Requires=network-online.target podman.socket
After=network-online.target podman.socket

[Service]
TimeoutStartSec=900
ExecStartPre=-/usr/bin/podman rm --force WolfPulseAudio
Restart=on-failure
RestartSec=5
StartLimitBurst=5

[Container]
AutoUpdate=registry
ContainerName=%p
HostName=%p
Image=ghcr.io/games-on-whales/wolf:stable
PublishPort=47984:47984/tcp
PublishPort=47989:47989/tcp
PublishPort=48010:48010/tcp
PublishPort=47999:47999/udp
PublishPort=48100:48100/udp
PublishPort=48200:48200/udp
PodmanArgs=--privileged --ipc=host --device-cgroup-rule "c 13:* rmw" --device-cgroup-rule "c 10:223 rmw" --group-add 104 --cap-add SYS_ADMIN --cap-add NET_ADMIN --cap-add SYS_NICE --cap-add MKNOD
AddDevice=/dev/dri
AddDevice=/dev/uinput
AddDevice=/dev/uhid
Volume=/dev/:/dev/:rw
Volume=/run/udev:/run/udev:rw
Volume=/etc/wolf/:/etc/wolf:z
Volume=/run/podman/podman.sock:/var/run/docker.sock:ro
Environment=WOLF_STOP_CONTAINER_ON_EXIT=TRUE
Environment=WOLF_INTERNAL_IP={{ ansible_facts['tailscale0']['ipv4']['address'] }}
Environment=WOLF_INTERNAL_MAC=00:00:00:00:00:00
Environment=WOLF_LOG_LEVEL=DEBUG
Environment=HOST_APPS_STATE_FOLDER=/etc/wolf

[Install]
WantedBy=multi-user.target
